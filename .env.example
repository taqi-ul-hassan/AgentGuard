APP_NAME="Agent Guard API"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
LOG_LEVEL="INFO"
API_PREFIX="/v1"

FIREWORKS_API_KEY=""
FIREWORKS_CLINICAL_MODEL="accounts/fireworks/models/llama-v3p1-8b-instruct"
FIREWORKS_VERIFIER_MODEL="accounts/fireworks/models/llama-v3p1-8b-instruct"
MODEL_TIMEOUT_SECONDS=30

DATABASE_URL="sqlite:///./agent_guard.db"
POLICY_PATH="app/policies/default_clinical_policies.yaml"
ENABLE_LOCAL_ROCM=false
LOCAL_ROCM_BASE_URL="http://localhost:8001/v1"
LOCAL_ROCM_TIMEOUT_SECONDS=60

AGENT_GUARD_API_BASE_URL="http://localhost:8000"
